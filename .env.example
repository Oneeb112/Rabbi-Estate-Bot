# =============================================
# Rabbi Estate Bot — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# Database (Railway MySQL)
DATABASE_URL="mysql://user:password@containers-us-west-XX.railway.app:XXXX/railway"

# WhatsApp Bot Config
ADMIN_NUMBER="923001234567"
# Group JID — get this after bot joins the group
GROUP_JID="120363XXXXXXXXXX@g.us"

# Bot Settings
BOT_NAME="Rabbi Estate Bot"
MAX_FORMS_PER_MONTH=500
NODE_ENV="production"

# Rate Limiting
MAX_MSGS_PER_USER_PER_HOUR=50

# Daily Lead Report Time (24hr format, PKT)
LEAD_REPORT_HOUR=9
